<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Leaderboard | 🧩 The Riddler </title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
  <link href="https://cdn.datatables.net/1.13.7/css/dataTables.bootstrap5.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@700;900&family=Rajdhani:wght@400;600;700&display=swap" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
</head>
<body>

<%- include('partials/navbar', { activePage: 'leaderboard' }) %>

<main class="main-content">
  <div class="container py-4">
    <div class="page-header d-flex justify-content-between align-items-center mb-4">
      <div>
        <h2 class="page-title"><i class="bi bi-trophy-fill me-2 text-warning"></i>Leaderboard</h2>
        <p class="page-subtitle">Rekap skor seluruh permainan</p>
      </div>
    </div>

    <!-- Top 3 Podium -->
    <div id="podiumSection" class="podium-section mb-5"></div>

    <!-- Full Table -->
    <div class="table-card">
      <div class="table-responsive">
        <table id="scoresTable" class="table table-hover align-middle" style="width:100%">
          <thead>
            <tr>
              <th>Peringkat</th>
              <th>Nama</th>
              <th>Email</th>
              <th>Skor</th>
              <th>Benar / Total</th>
              <th>Tanggal Main</th>
              <th>Aksi</th>
            </tr>
          </thead>
        </table>
      </div>
    </div>
  </div>
</main>

<%- include('partials/footer') %>

<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/1.13.7/js/dataTables.bootstrap5.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="/js/main.js"></script>
<script>
$(document).ready(function () {
  var table = $('#scoresTable').DataTable({
    ajax: {
      url: '/scores/json',
      dataSrc: function(json) {
        // Render podium dari data pertama
        renderPodium(json.data.slice(0, 3));
        return json.data;
      }
    },
    columns: [
      { data: null, render: function(d,t,r,m) {
          var rank = m.row + 1;
          var medal = rank === 1 ? '🥇' : rank === 2 ? '🥈' : rank === 3 ? '🥉' : rank;
          return '<span class="rank-badge">'+medal+'</span>';
      }, orderable: false },
      { data: 'name', render: function(data) {
          var initials = data.split(' ').map(w=>w[0]).join('').substring(0,2).toUpperCase();
          return `<div class="d-flex align-items-center gap-2">
            <div class="avatar-circle">${initials}</div>
            <strong>${data}</strong>
          </div>`;
      }},
      { data: 'email' },
      { data: 'score', render: function(data) {
          return '<span class="score-display big">'+data+'</span>';
      }},
      { data: 'correct_answers', render: function(data, type, row) {
          var pct = row.total_questions > 0 ? Math.round((data/row.total_questions)*100) : 0;
          return `<div>
            <span>${data} / ${row.total_questions}</span>
            <div class="progress mt-1" style="height:4px;">
              <div class="progress-bar bg-warning" style="width:${pct}%"></div>
            </div>
          </div>`;
      }},
      { data: 'played_at' },
      { data: 'id', orderable: false, render: function(data) {
          return `<button class="btn btn-sm btn-delete" onclick="deleteScore(${data})"><i class="bi bi-trash-fill"></i></button>`;
      }}
    ],
    order: [[3, 'desc']],
    language: { url: 'https://cdn.datatables.net/plug-ins/1.13.7/i18n/id.json' },
    pageLength: 10
  });

  function renderPodium(data) {
    if (!data.length) {
      $('#podiumSection').html('<p class="text-center text-muted">Belum ada data skor.</p>');
      return;
    }
    var html = '<div class="podium-wrapper">';
    var order = [1, 0, 2]; // silver, gold, bronze
    var podiumClass = ['podium-2nd', 'podium-1st', 'podium-3rd'];
    var medal = ['🥈', '🥇', '🥉'];
    order.forEach(function(i, pos) {
      if (!data[i]) return;
      var initials = data[i].name.split(' ').map(w=>w[0]).join('').substring(0,2).toUpperCase();
      html += `<div class="podium-item ${podiumClass[pos]}">
        <div class="podium-avatar">${initials}</div>
        <div class="podium-medal">${medal[pos]}</div>
        <div class="podium-name">${data[i].name}</div>
        <div class="podium-score">${data[i].score} pts</div>
        <div class="podium-base"></div>
      </div>`;
    });
    html += '</div>';
    $('#podiumSection').html(html);
  }

  window.deleteScore = function(id) {
    Swal.fire({
      title: 'Hapus Skor?',
      text: 'Data skor ini akan dihapus permanen!',
      icon: 'warning',
      showCancelButton: true,
      confirmButtonColor: '#c0392b',
      cancelButtonColor: '#555',
      confirmButtonText: 'Ya, Hapus!',
      cancelButtonText: 'Batal',
      background: '#1a1a2e',
      color: '#fff'
    }).then((result) => {
      if (result.isConfirmed) {
        $.ajax({
          url: '/scores/' + id,
          type: 'DELETE',
          success: function() {
            table.ajax.reload();
            Swal.fire({ title: 'Terhapus!', icon: 'success', background: '#1a1a2e', color: '#fff', timer: 1500, showConfirmButton: false });
          }
        });
      }
    });
  };
});
</script>
</body>
</html>
