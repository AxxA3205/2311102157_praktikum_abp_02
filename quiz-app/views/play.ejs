<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Main Quiz | 🧩 The Riddler </title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@700;900&family=Rajdhani:wght@400;600;700&display=swap" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
  <link href="/css/play.css" rel="stylesheet">
</head>
<body class="play-body">

<!-- SCREEN 1: Pilih Peserta -->
<div id="screen-select" class="play-screen active">
  <div class="play-logo">
    <div class="play-logo-icon">🎯</div>
    <h1 class="play-logo-title">QuizMaster</h1>
    <p class="play-logo-sub">Who Wants To Be A Millionaire?</p>
  </div>
  <div class="select-card">
    <h4 class="select-title">Siapa yang akan bermain?</h4>
    <% if (participants.length === 0) { %>
      <div class="alert alert-warning text-center">
        Belum ada peserta terdaftar. 
        <a href="/participants/add" class="alert-link">Daftar sekarang</a>
      </div>
    <% } else { %>
      <div class="participant-grid">
        <% participants.forEach(function(p) { %>
          <div class="participant-btn" data-id="<%= p.id %>" data-name="<%= p.name %>">
            <div class="participant-btn-avatar"><%= p.name.split(' ').map(w=>w[0]).join('').substring(0,2).toUpperCase() %></div>
            <div class="participant-btn-name"><%= p.name %></div>
          </div>
        <% }); %>
      </div>
      <button id="startQuizBtn" class="btn btn-start-quiz mt-4" disabled>
        <i class="bi bi-play-circle-fill me-2"></i>Mulai Quiz
      </button>
    <% } %>
    <div class="mt-3 text-center">
      <a href="/" class="back-link"><i class="bi bi-arrow-left me-1"></i>Kembali ke Dashboard</a>
    </div>
  </div>
</div>

<!-- SCREEN 2: Quiz Game -->
<div id="screen-quiz" class="play-screen">
  <div class="quiz-layout">
    <!-- Left: Prize Ladder -->
    <div class="prize-ladder" id="prizeLadder"></div>

    <!-- Center: Question -->
    <div class="quiz-center">
      <!-- Header Info -->
      <div class="quiz-header">
        <div class="quiz-player-info">
          <span class="quiz-player-label">Peserta:</span>
          <span class="quiz-player-name" id="playerName">-</span>
        </div>
        <div class="quiz-progress">
          Soal <span id="currentQ">1</span> / <span id="totalQ">10</span>
        </div>
        <div class="quiz-difficulty" id="difficultyBadge">-</div>
      </div>

      <!-- Question Box -->
      <div class="question-box">
        <div class="question-number">Pertanyaan #<span id="qNumber">1</span></div>
        <div class="question-text" id="questionText">Memuat soal...</div>
      </div>

      <!-- Options -->
      <div class="options-grid" id="optionsGrid">
        <div class="option-btn" id="opt-A" data-answer="A">
          <span class="opt-letter">A</span>
          <span class="opt-text" id="optA">-</span>
        </div>
        <div class="option-btn" id="opt-B" data-answer="B">
          <span class="opt-letter">B</span>
          <span class="opt-text" id="optB">-</span>
        </div>
        <div class="option-btn" id="opt-C" data-answer="C">
          <span class="opt-letter">C</span>
          <span class="opt-text" id="optC">-</span>
        </div>
        <div class="option-btn" id="opt-D" data-answer="D">
          <span class="opt-letter">D</span>
          <span class="opt-text" id="optD">-</span>
        </div>
      </div>

      <!-- Lifeline: 50:50 -->
      <div class="lifeline-bar">
        <button class="lifeline-btn" id="lifeline5050" title="50:50">
          <span>50</span><span class="lifeline-divider">:</span><span>50</span>
        </button>
        <span class="lifeline-label">Lifeline tersisa</span>
      </div>
    </div>
  </div>
</div>

<!-- SCREEN 3: Hasil -->
<div id="screen-result" class="play-screen">
  <div class="result-card">
    <div class="result-icon" id="resultIcon">🏆</div>
    <h2 class="result-title" id="resultTitle">Selamat!</h2>
    <p class="result-subtitle" id="resultSubtitle">Kamu telah menyelesaikan quiz</p>
    <div class="result-score-box">
      <div class="result-score-label">Skor Akhir</div>
      <div class="result-score-value" id="finalScore">0</div>
    </div>
    <div class="result-stats">
      <div class="result-stat">
        <div class="result-stat-val" id="statCorrect">0</div>
        <div class="result-stat-label">Benar</div>
      </div>
      <div class="result-stat">
        <div class="result-stat-val" id="statWrong">0</div>
        <div class="result-stat-label">Salah</div>
      </div>
      <div class="result-stat">
        <div class="result-stat-val" id="statTotal">0</div>
        <div class="result-stat-label">Total Soal</div>
      </div>
    </div>
    <div class="d-flex gap-3 justify-content-center mt-4 flex-wrap">
      <button class="btn btn-play-again" id="playAgainBtn">
        <i class="bi bi-arrow-repeat me-2"></i>Main Lagi
      </button>
      <a href="/scores" class="btn btn-see-score">
        <i class="bi bi-trophy-fill me-2"></i>Lihat Leaderboard
      </a>
      <a href="/" class="btn btn-back-home">
        <i class="bi bi-house-fill me-2"></i>Dashboard
      </a>
    </div>
  </div>
</div>

<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="/js/play.js"></script>
</body>
</html>
