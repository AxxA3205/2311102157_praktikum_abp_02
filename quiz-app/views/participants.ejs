<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Peserta | 🧩 The Riddler</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
  <link href="https://cdn.datatables.net/1.13.7/css/dataTables.bootstrap5.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@700;900&family=Rajdhani:wght@400;600;700&display=swap" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
</head>
<body>

<%- include('partials/navbar', { activePage: 'participants' }) %>

<main class="main-content">
  <div class="container py-4">
    <div class="page-header d-flex justify-content-between align-items-center mb-4">
      <div>
        <h2 class="page-title"><i class="bi bi-people-fill me-2"></i>Manajemen Peserta</h2>
        <p class="page-subtitle">Daftar semua peserta terdaftar</p>
      </div>
      <a href="/participants/add" class="btn btn-add">
        <i class="bi bi-person-plus-fill me-2"></i>Tambah Peserta
      </a>
    </div>

    <div class="table-card">
      <div class="table-responsive">
        <table id="participantsTable" class="table table-hover align-middle" style="width:100%">
          <thead>
            <tr>
              <th>#</th>
              <th>Nama</th>
              <th>Email</th>
              <th>Total Permainan</th>
              <th>Skor Terbaik</th>
              <th>Terdaftar</th>
              <th>Aksi</th>
            </tr>
          </thead>
        </table>
      </div>
    </div>
  </div>
</main>

<%- include('partials/footer') %>

<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/1.13.7/js/dataTables.bootstrap5.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="/js/main.js"></script>
<script>
$(document).ready(function () {
  var table = $('#participantsTable').DataTable({
    ajax: { url: '/participants/json', dataSrc: 'data' },
    columns: [
      { data: null, render: function(d,t,r,m){ return m.row+1; }, orderable: false },
      { data: 'name', render: function(data) {
          var initials = data.split(' ').map(w=>w[0]).join('').substring(0,2).toUpperCase();
          return `<div class="d-flex align-items-center gap-2">
            <div class="avatar-circle">${initials}</div>
            <strong>${data}</strong>
          </div>`;
      }},
      { data: 'email' },
      { data: 'total_games', render: function(data) {
          return '<span class="badge badge-games">'+data+' games</span>';
      }},
      { data: 'best_score', render: function(data) {
          return '<span class="score-display">'+data+'</span>';
      }},
      { data: 'created_at', render: function(data) {
          return new Date(data).toLocaleDateString('id-ID');
      }},
      { data: 'id', orderable: false, render: function(data) {
          return `<div class="d-flex gap-2">
            <a href="/participants/${data}/edit" class="btn btn-sm btn-edit"><i class="bi bi-pencil-fill"></i></a>
            <button class="btn btn-sm btn-delete" onclick="deleteParticipant(${data})"><i class="bi bi-trash-fill"></i></button>
          </div>`;
      }}
    ],
    language: { url: 'https://cdn.datatables.net/plug-ins/1.13.7/i18n/id.json' },
    pageLength: 10
  });

  window.deleteParticipant = function(id) {
    Swal.fire({
      title: 'Hapus Peserta?',
      text: 'Seluruh data skor peserta ini juga akan ikut terhapus!',
      icon: 'warning',
      showCancelButton: true,
      confirmButtonColor: '#c0392b',
      cancelButtonColor: '#555',
      confirmButtonText: 'Ya, Hapus!',
      cancelButtonText: 'Batal',
      background: '#1a1a2e',
      color: '#fff'
    }).then((result) => {
      if (result.isConfirmed) {
        $.ajax({
          url: '/participants/' + id,
          type: 'DELETE',
          success: function() {
            table.ajax.reload();
            Swal.fire({ title: 'Terhapus!', text: 'Peserta berhasil dihapus.', icon: 'success', background: '#1a1a2e', color: '#fff', timer: 1500, showConfirmButton: false });
          }
        });
      }
    });
  };
});
</script>
</body>
</html>
