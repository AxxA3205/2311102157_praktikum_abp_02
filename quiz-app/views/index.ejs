<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard | 🧩 The Riddler </title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
  <link href="https://cdn.datatables.net/1.13.7/css/dataTables.bootstrap5.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@700;900&family=Rajdhani:wght@400;600;700&display=swap" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
</head>
<body>

<%- include('partials/navbar', { activePage: 'home' }) %>

<main class="main-content">
  <!-- Hero Section -->
  <div class="hero-section">
    <div class="hero-bg"></div>
    <div class="container text-center py-5">
      <div class="hero-badge mb-3">WHO WANTS TO BE A MILLIONAIRE?</div>
      <h1 class="hero-title">🧩 The Riddler</h1>
      <p class="hero-subtitle">Welcome to the game!</p>
      <a href="/play" class="btn btn-hero mt-3">
        <i class="bi bi-play-circle-fill me-2"></i>Mulai Quiz Sekarang
      </a>
    </div>
  </div>

  <!-- Stats Cards -->
  <div class="container py-5">
    <div class="row g-4 justify-content-center">
      <div class="col-md-4">
        <div class="stat-card stat-card-blue">
          <div class="stat-icon"><i class="bi bi-question-circle-fill"></i></div>
          <div class="stat-number"><%= total_questions %></div>
          <div class="stat-label">Total Soal</div>
          <a href="/questions" class="stat-link">Kelola Soal <i class="bi bi-arrow-right"></i></a>
        </div>
      </div>
      <div class="col-md-4">
        <div class="stat-card stat-card-gold">
          <div class="stat-icon"><i class="bi bi-people-fill"></i></div>
          <div class="stat-number"><%= total_participants %></div>
          <div class="stat-label">Total Peserta</div>
          <a href="/participants" class="stat-link">Kelola Peserta <i class="bi bi-arrow-right"></i></a>
        </div>
      </div>
      <div class="col-md-4">
        <div class="stat-card stat-card-green">
          <div class="stat-icon"><i class="bi bi-trophy-fill"></i></div>
          <div class="stat-number"><%= total_scores %></div>
          <div class="stat-label">Total Permainan</div>
          <a href="/scores" class="stat-link">Lihat Leaderboard <i class="bi bi-arrow-right"></i></a>
        </div>
      </div>
    </div>

    <!-- Quick Actions -->
    <div class="row g-3 mt-4">
      <div class="col-12">
        <h5 class="section-title">Aksi Cepat</h5>
      </div>
      <div class="col-md-3 col-6">
        <a href="/questions/add" class="quick-action-card">
          <i class="bi bi-plus-circle-fill"></i>
          <span>Tambah Soal</span>
        </a>
      </div>
      <div class="col-md-3 col-6">
        <a href="/participants/add" class="quick-action-card">
          <i class="bi bi-person-plus-fill"></i>
          <span>Daftar Peserta</span>
        </a>
      </div>
      <div class="col-md-3 col-6">
        <a href="/play" class="quick-action-card">
          <i class="bi bi-controller"></i>
          <span>Main Quiz</span>
        </a>
      </div>
      <div class="col-md-3 col-6">
        <a href="/scores" class="quick-action-card">
          <i class="bi bi-bar-chart-fill"></i>
          <span>Leaderboard</span>
        </a>
      </div>
    </div>
  </div>
</main>

<%- include('partials/footer') %>

<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="/js/main.js"></script>
</body>
</html>
