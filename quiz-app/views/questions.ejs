<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Bank Soal | 🧩 The Riddler </title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
  <link href="https://cdn.datatables.net/1.13.7/css/dataTables.bootstrap5.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@700;900&family=Rajdhani:wght@400;600;700&display=swap" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
</head>
<body>

<%- include('partials/navbar', { activePage: 'questions' }) %>

<main class="main-content">
  <div class="container py-4">
    <!-- Page Header -->
    <div class="page-header d-flex justify-content-between align-items-center mb-4">
      <div>
        <h2 class="page-title"><i class="bi bi-question-circle-fill me-2"></i>Bank Soal</h2>
        <p class="page-subtitle">Kelola semua pertanyaan kuis</p>
      </div>
      <a href="/questions/add" class="btn btn-add">
        <i class="bi bi-plus-circle-fill me-2"></i>Tambah Soal
      </a>
    </div>

    <!-- Table Card -->
    <div class="table-card">
      <div class="table-responsive">
        <table id="questionsTable" class="table table-hover align-middle" style="width:100%">
          <thead>
            <tr>
              <th>#</th>
              <th>Pertanyaan</th>
              <th>Jawaban Benar</th>
              <th>Tingkat Kesulitan</th>
              <th>Level Hadiah</th>
              <th>Aksi</th>
            </tr>
          </thead>
        </table>
      </div>
    </div>
  </div>
</main>

<%- include('partials/footer') %>

<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/1.13.7/js/dataTables.bootstrap5.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="/js/main.js"></script>
<script>
$(document).ready(function () {
  var table = $('#questionsTable').DataTable({
    ajax: {
      url: '/questions/json',
      dataSrc: 'data'
    },
    columns: [
      { data: null, render: function(data, type, row, meta) { return meta.row + 1; }, orderable: false },
      { data: 'question_text', render: function(data) {
          return '<span title="'+ data +'">'+ (data.length > 60 ? data.substring(0, 60) + '...' : data) +'</span>';
      }},
      { data: 'correct_answer', render: function(data, type, row) {
          var optKey = 'option_' + data.toLowerCase();
          return '<span class="badge badge-answer">'+data+': '+row[optKey]+'</span>';
      }},
      { data: 'difficulty', render: function(data) {
          var cls = data === 'easy' ? 'badge-easy' : data === 'medium' ? 'badge-medium' : 'badge-hard';
          var label = data === 'easy' ? 'Mudah' : data === 'medium' ? 'Sedang' : 'Sulit';
          return '<span class="badge '+cls+'">'+label+'</span>';
      }},
      { data: 'prize_level', render: function(data) {
          return '<span class="prize-level">Lv. '+data+'</span>';
      }},
      { data: 'id', orderable: false, render: function(data) {
          return `
            <div class="d-flex gap-2">
              <a href="/questions/${data}/edit" class="btn btn-sm btn-edit"><i class="bi bi-pencil-fill"></i></a>
              <button class="btn btn-sm btn-delete" onclick="deleteQuestion(${data})"><i class="bi bi-trash-fill"></i></button>
            </div>`;
      }}
    ],
    language: {
      url: 'https://cdn.datatables.net/plug-ins/1.13.7/i18n/id.json'
    },
    pageLength: 10,
    order: [[0, 'asc']]
  });

  // Auto-refresh table
  window.deleteQuestion = function(id) {
    Swal.fire({
      title: 'Hapus Soal?',
      text: 'Data soal ini akan dihapus permanen!',
      icon: 'warning',
      showCancelButton: true,
      confirmButtonColor: '#c0392b',
      cancelButtonColor: '#555',
      confirmButtonText: 'Ya, Hapus!',
      cancelButtonText: 'Batal',
      background: '#1a1a2e',
      color: '#fff'
    }).then((result) => {
      if (result.isConfirmed) {
        $.ajax({
          url: '/questions/' + id,
          type: 'DELETE',
          success: function() {
            table.ajax.reload();
            Swal.fire({ title: 'Terhapus!', text: 'Soal berhasil dihapus.', icon: 'success', background: '#1a1a2e', color: '#fff', timer: 1500, showConfirmButton: false });
          }
        });
      }
    });
  };
});
</script>
</body>
</html>
